<h1>Vets</h1>

<table class="table table-striped table-bordered">
  <thead>
    <tr>
      <th>Full name</th>
      <th>Email</th>
      <th>Specialization</th>
    </tr>
  </thead>
  <tbody>
    <% Vet.by_specialization("Vaccination").each do |vet| %>
      <tr>
        <td><%= link_to "#{vet.first_name} #{vet.last_name}", vet_path(vet) %></td>
        <td><%= vet.email %></td>
        <td><%= vet.specialization %></td>
      </tr>
    <% end %>
  </tbody>
</table>