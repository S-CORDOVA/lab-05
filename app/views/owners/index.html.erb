<h1>Owners</h1>

<table class="table table-striped table-bordered">
  <thead>
    <tr>
      <th>Full name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Number of pets</th>
    </tr>
  </thead>
  <tbody>
    <% @owners.each do |owner| %>
      <tr>
        <td><%= link_to "#{owner.first_name} #{owner.last_name}", owner_path(owner) %></td>
        <td><%= owner.email %></td>
        <td><%= owner.phone %></td>
        <td><%= owner.pets.size %></td>
      </tr>
    <% end %>
  </tbody>
</table>